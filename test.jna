save
    push 8
    push 2
    push 1 reverse
    push 7
    push 3
    push 1
    push 5
    push 4
makelist

; Digits > 0
aspair
    zero lt
where

; In order
sort

; A list of numbers 1 - l of the same length
copy length range one add
makelist transpose ; Into pairs
aspair
    unpack eq
takewhile ; All the pairs that are equal
length one add